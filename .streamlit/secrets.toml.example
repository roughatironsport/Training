# -----------------------------------------------------------------------------
# Vorlage für Streamlit-Secrets.
#
# 1. Kopiere diese Datei nach:  .streamlit/secrets.toml
# 2. Trage deine echten Werte ein.
# 3. .streamlit/secrets.toml NIEMALS committen (steht in .gitignore).
# -----------------------------------------------------------------------------

# ---- MongoDB: Komponenten getrennt (EMPFOHLEN, sonderzeichensicher) ----------
# Username + Passwort werden im Code automatisch URL-encodiert.
mongo_username = "DEIN_USER"
mongo_password = "DEIN_PASSWORT"
mongo_host     = "train.brex0oc.mongodb.net"
mongo_appname  = "train"

# ---- ALTERNATIVE: fertiger MongoDB-Connection-String ------------------------
# Nur nutzen, wenn du den String selbst pflegen willst (dann oben mongo_* weg).
# Sonderzeichen im Passwort hier von Hand encodieren (@ -> %40, # -> %23 ...).
# mongo_uri = "mongodb+srv://USER:PASSWORT@train.brex0oc.mongodb.net/?appName=train"


# ---- LOGIN-Passwörter (App-Login je Nutzer) ---------------------------------
# Jeder Nutzer meldet sich mit seinem eigenen Passwort an. Frei wählbar,
# hat nichts mit dem MongoDB-Passwort zu tun.
[passwords]
Patric  = "BITTE_PASSWORT_SETZEN"
Sandeep = "BITTE_PASSWORT_SETZEN"
