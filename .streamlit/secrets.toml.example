# -----------------------------------------------------------------------------
# Vorlage für Streamlit-Secrets.
#
# 1. Kopiere diese Datei nach:  .streamlit/secrets.toml
# 2. Trage deine echten Atlas-Zugangsdaten ein.
# 3. .streamlit/secrets.toml NIEMALS committen (steht in .gitignore).
# -----------------------------------------------------------------------------

# ---- EMPFOHLEN: Komponenten getrennt (sonderzeichensicher) ------------------
# Username + Passwort werden im Code automatisch URL-encodiert, du musst dich
# also NICHT um Sonderzeichen (@ : / ? # ...) im Passwort kümmern.
mongo_username = "DEIN_USER"
mongo_password = "DEIN_PASSWORT"
mongo_host     = "train.brex0oc.mongodb.net"
mongo_appname  = "train"

# ---- ALTERNATIVE: fertiger Connection-String --------------------------------
# Nur nutzen, wenn du den String komplett selbst pflegen willst. Dann oben die
# vier mongo_*-Zeilen weglassen. Sonderzeichen im Passwort müssen hier von Hand
# encodiert werden (z. B. @ -> %40, # -> %23).
# mongo_uri = "mongodb+srv://USER:PASSWORT@train.brex0oc.mongodb.net/?appName=train"
